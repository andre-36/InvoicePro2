# Environment Variables Template
# Copy this file to .env and fill in the values

# Database Connection
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://invoicepro:invoice_secret@db:5432/invoicepro_db

# Session Secret (Random string for security)
SESSION_SECRET=change_me_to_something_very_long_and_random

# Environment
NODE_ENV=production
PORT=5000
